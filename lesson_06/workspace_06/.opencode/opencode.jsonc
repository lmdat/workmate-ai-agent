{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "excalidraw": {
            "type": "local",
            "command": ["npx", "-y", "@scofieldfree/excalidraw-mcp"],
            "enabled": true
        },
        "chrome-devtools": {
            "type": "local",
            "command": [
                "npx", 
                "-y", 
                "chrome-devtools-mcp@latest"
            ],
            "enabled": true
        },
        "tavily-local": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "tavily-mcp@latest"
            ],
            "environment": {
                "TAVILY_API_KEY": "YOUR_API_KEY"
            },
            "enabled": true
        },
        "tavily-remote": {
            "type": "remote",
            "url": "https://mcp.tavily.com/mcp/?tavilyApiKey=YOUR_API_KEY",
            "enabled": false
        }
    }
}