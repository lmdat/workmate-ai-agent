{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "excalidraw-mcp": {
            "type": "local",
            "command": ["npx", "-y", "@scofieldfree/excalidraw-mcp"],
            "enabled": false
        },
        "chrome-devtools-mcp": {
            "type": "local",
            "command": [
                "npx", 
                "-y", 
                "chrome-devtools-mcp@latest"
            ],
            "enabled": true
        },
        "tavily-local-mcp": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "tavily-mcp@latest"
            ],
            "environment": {
                "TAVILY_API_KEY": "YOUR_API_KEY"
            },
            "enabled": true
        },
        "tavily-remote-mcp": {
            "type": "remote",
            "url": "https://mcp.tavily.com/mcp/?tavilyApiKey=YOUR_API_KEY",
            "enabled": false
        },
		"google-sheets-mcp": {
            "type": "local",
            "command": [
                "npx", "-y", "@lmdat/google-sheets-oauth-mcp@latest"
            ],
            "timeout": 15000,
            "enabled": true,
            "environment": {
                "GOOGLE_OAUTH_CLIENT_ID": "",
                "GOOGLE_OAUTH_CLIENT_SECRET": "",                
                "MCP_GSHEETS_TOKEN_DIR": "C:\\Users\\<USERNAME>\\.config\\mcp-googlesheet"
            }
        }
    }
}